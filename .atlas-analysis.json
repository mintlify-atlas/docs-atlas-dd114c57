  "keyFeatures": [
    "Lavalink 4.0+ support with full API coverage",
    "Plugin system for extending functionality",
    "Event-driven architecture for player updates",
    "Audio filters and effects (equalizer, timescale, tremolo, etc.)",
    "Session resuming and reconnection handling",
    "Load balancing across multiple Lavalink nodes",
    "Track loading with support for search, playlists, and direct URLs",
    "Voice state management and WebSocket handling"
  ],
  "publicApiSurface": [
    "disgolink.New() - Create a new Lavalink client",
    "Client.AddNode() - Add a Lavalink node",
    "Client.Player() - Get or create a player for a guild",
    "Client.BestNode() - Get the best available node",
    "Node.LoadTracks() - Load tracks from an identifier",
    "Node.LoadTracksHandler() - Load tracks with result handler",
    "Player.Update() - Update player state (track, volume, filters, etc.)",
    "Player.Destroy() - Destroy a player",
    "WithListenerFunc() - Add event listeners",
    "WithPlugins() - Register plugins",
    "lavalink.WithTrack() - Set the current track",
    "lavalink.WithVolume() - Set player volume",
    "lavalink.WithPaused() - Pause/resume playback",
    "lavalink.WithFilters() - Apply audio filters",
    "OnVoiceStateUpdate() - Handle Discord voice state updates",
    "OnVoiceServerUpdate() - Handle Discord voice server updates"
  ]
}
